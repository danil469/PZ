print("\nПример 9: Среднее арифметическое")
import random
while True:
    try:
        n = int(input('Введите размер массива: '))
        break
    except:
        print("Ошибка, введите целое число")

a, b = [], []
t = 0
while t < n:
    a.append(random.randint(1, 2))
    t += 1
print('Исходный массив:', a)

t = 0
i = 0
while t < n:
    s = 0
    while i < n:
        s += a[i]
        i += 1
    b.append(s / (n - t))
    t += 1
    i = t
print('Массив B:', b)
