print("Задача 3: Ближайшая точка")
print("=" * 40)

while True:
    try:
        N = int(input("Введите количество точек N: "))
        break
    except:
        print("Ошибка, введите целое число")

x_list = []
y_list = []

for i in range(N):
    while True:
        try:
            x = float(input(f"Точка {i+1}, координата x: "))
            y = float(input(f"Точка {i+1}, координата y: "))
            x_list.append(x)
            y_list.append(y)
            break
        except:
            print("Ошибка, введите числа")

blizhayshaya = (0.0, 0.0)
min_rasstoyanie = 1000000000
est_tochki = False

for i in range(N):
    x = x_list[i]
    y = y_list[i]
    
    if (x > 0 and y > 0) or (x < 0 and y < 0):
        est_tochki = True
        rasstoyanie = ((x - 0) ** 2 + (y - 0) ** 2) ** 0.5
        
        if rasstoyanie < min_rasstoyanie:
            min_rasstoyanie = rasstoyanie
            blizhayshaya = (x, y)

if est_tochki:
    print(f"Ближайшая точка: ({blizhayshaya[0]}, {blizhayshaya[1]})")
else:
    print("Нет точек в 1 или 3 четверти")
    print(f"Точка: ({blizhayshaya[0]}, {blizhayshaya[1]})")

