print("\nПример 7: Увеличение четных чисел")
import random
def PrintList(ListAppend):
    for element in ListAppend:
        print(element, end=' ')
    print()

while True:
    try:
        d = int(input('Введите размер массива: '))
        break
    except:
        print("Ошибка, введите целое число")

ListAppend = []
t = 0
k = 0
while t < d:
    chislo = random.randint(-100, 100)
    ListAppend.append(chislo)
    if chislo % 2 == 0:
        k = chislo
    t += 1

print('Исходный массив')
PrintList(ListAppend)
print('Последнее четное число:', k)

for i in range(len(ListAppend)):
    if ListAppend[i] % 2 == 0:
        ListAppend[i] += k

print('Полученный список')
PrintList(ListAppend)

