import math

def TrianglePS(a, P, S):
    P = 3 * a
    S = (a ** 2) * math.sqrt(3) / 4
    return P, S

storoni = []
for i in range(3):
    while True:
        try:
            a = float(input(f"Введите сторону треугольника {i+1}: "))
            if a > 0:
                storoni.append(a)
                break
            else:
                print("Сторона должна быть больше 0")
        except:
            print("Ошибка, введите число")

for i, a in enumerate(storoni, 1):
    P, S = TrianglePS(a, 0, 0)
    print(f"Треугольник {i}: сторона = {a:.2f}")
    print(f"  Периметр P = {P:.2f}")
    print(f"  Площадь S = {S:.2f}")

