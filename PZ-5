print("\n1. У какого числа больше сумма цифр")
def summa_cifr(chislo):
    summa = 0
    chislo = abs(chislo)
    while chislo > 0:
        summa += chislo % 10
        chislo = chislo // 10
    return summa

chisla = []
for i in range(3):
    while True:
        try:
            chislo = int(input(f"Число {i+1}: "))
            chisla.append(chislo)
            break
        except:
            print("Ошибка, введите целое число")

max_sum = -1
nomer = 0
for i, ch in enumerate(chisla):
    s = summa_cifr(ch)
    print(f"Число {ch}: сумма цифр = {s}")
    if s > max_sum:
        max_sum = s
        nomer = i + 1

print(f"Наибольшая сумма цифр у числа {nomer}")

print("\n2. Периметр и площадь прямоугольника")
def rectangle(a, b):
    P = 2 * (a + b)
    S = a * b
    return P, S

