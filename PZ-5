def gorizontal(simvol, dlina):
    return simvol * dlina

def vertikal(simvol, shirina, slovo=""):
    if slovo:
        return f"{simvol}{slovo.center(shirina-2)}{simvol}"
    else:
        return f"{simvol}{' '*(shirina-2)}{simvol}"

slovo = input("Введите слово: ")
simvol = input("Введите символ для рамки: ")

shirina = len(slovo) + 4

print(gorizontal(simvol, shirina))
print(vertikal(simvol, shirina, slovo))
print(gorizontal(simvol, shirina))

