    try:
        a = float(input("Длина прямоугольника: "))
        b = float(input("Ширина прямоугольника: "))
        if a > 0 and b > 0:
            break
        else:
            print("Длины должны быть положительными")
    except:
        print("Ошибка, введите числа")

P, S = rectangle(a, b)
print(f"Периметр: {P}")
print(f"Площадь: {S}")

