print("Задача 1: Приближенное вычисление arctg(x)")
print("=" * 50)

x = float(input("Введите X: "))
n = int(input("Введите N: "))

result = 0
for i in range(n + 1):
    stepen = 2 * i + 1
    chislitel = (-1) ** i * (x ** stepen)
    znamenatel = stepen
    slagaemoe = chislitel / znamenatel
    result = result + slagaemoe

print("Результат:", result)

