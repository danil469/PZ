print("\n4. Сумма факториалов")
n = int(input("n: "))

def factorial(ch):
    res = 1
    for i in range(1, ch+1):
        res = res * i
    return res

obsh_sum = 0
for i in range(1, n+1):
    obsh_sum = obsh_sum + factorial(i)

print("Сумма факториалов:", obsh_sum)

